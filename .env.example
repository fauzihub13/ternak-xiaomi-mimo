# ──────────────────────────────────────────────────────────────────────────
# CapSolver API key (reCAPTCHA Enterprise solver)
# ──────────────────────────────────────────────────────────────────────────
CAPSOLVER_API_KEY=your_capsolver_api_key_here

# ──────────────────────────────────────────────────────────────────────────
# Email yang akan didaftarkan
# Disarankan pakai email dengan catch-all → forward ke 1 inbox + IMAP.
# ──────────────────────────────────────────────────────────────────────────
EMAIL=your_email@example.com
XIAOMI_PASSWORD=YourStrongPassword!2026

# ──────────────────────────────────────────────────────────────────────────
# IMAP untuk membaca kode verifikasi 6-digit
# Gmail: pakai App Password (bukan password akun)
# ──────────────────────────────────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_gmail@gmail.com
IMAP_PASS=your_gmail_app_password

# ──────────────────────────────────────────────────────────────────────────
# Proxy (WAJIB untuk VPS / data-center IP — di-block 503)
# Pakai WARP SOCKS5 atau residential proxy.
# Set USE_PROXY=0 untuk disable (testing lokal saja).
# ──────────────────────────────────────────────────────────────────────────
USE_PROXY=1
PROXY_URL=socks5://127.0.0.1:40000

# ──────────────────────────────────────────────────────────────────────────
# Region (lihat kode Xiaomi)
# ID = Indonesia, US = United States, dll.
# ──────────────────────────────────────────────────────────────────────────
REGION=ID

# ──────────────────────────────────────────────────────────────────────────
# (opsional) Test Cloudflare Email Routing setup
# Set TEST_DOMAIN ke domain Cloudflare Anda untuk run setup_test.py
# ──────────────────────────────────────────────────────────────────────────
# TEST_DOMAIN=mimo.domain-anda.com
# TEST_SENDER_PASS=                    # kalau beda dari IMAP_PASS