# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  mimo-register — Environment Variables                                 ║
# ║                                                                        ║
# ║  Copy file ini ke .env dan isi nilainya:                              ║
# ║    cp .env.example .env                                                ║
# ║    nano .env                                                           ║
# ╚══════════════════════════════════════════════════════════════════════════╝


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ WAJIB — CapSolver (captcha solver)                                     │
# └─────────────────────────────────────────────────────────────────────────┘
# Daftar di https://dashboard.capsolver.com/
# Pakai untuk solve reCAPTCHA Enterprise Xiaomi.
CAPSOLVER_API_KEY=your_capsolver_api_key_here


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ WAJIB — Akun Xiaomi (yang akan didaftarkan / di-refresh)               │
# └─────────────────────────────────────────────────────────────────────────┘
# Untuk strategi catch_all: hanya perlu di-set kalau Anda jalankan
# `mimo.batch` atau `mimo.register` manual. Untuk `from_file` strategy,
# email di-supply via file.
EMAIL=your_email@example.com
XIAOMI_PASSWORD=YourStrongPassword!2026


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ WAJIB — IMAP (untuk baca OTP email verifikasi)                         │
# └─────────────────────────────────────────────────────────────────────────┘
# Gmail: pakai App Password, bukan password akun biasa.
#   1. https://myaccount.google.com/security → enable 2FA
#   2. https://myaccount.google.com/apppasswords → generate
# Outlook/Yahoo/Yandex: pakai password biasa + IMAP enabled
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_gmail@gmail.com
IMAP_PASS=your_gmail_app_password


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ WAJIB untuk VPS — Proxy WARP / residential                             │
# └─────────────────────────────────────────────────────────────────────────┘
# VPS IP di-block 503 oleh account.xiaomi.com. Pakai WARP SOCKS5 atau
# residential proxy. Untuk local testing, set USE_PROXY=0.
USE_PROXY=1
PROXY_URL=socks5://127.0.0.1:40000


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ OPSIONAL — Cloudflare API (untuk bulk setup catch-all email)           │
# └─────────────────────────────────────────────────────────────────────────┘
# Token: https://dash.cloudflare.com/profile/api-tokens
# Zone ID: klik kanan domain di dashboard → Copy Zone ID
# Account ID: klik avatar pojok kanan atas → Copy Account ID
# Detail: docs/cloudflare-api-setup.md
CF_API_TOKEN=your_cloudflare_api_token
CF_ZONE_ID=your_zone_id
CF_ACCOUNT_ID=your_account_id
CF_DEST_EMAIL=email.anda@gmail.com


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ OPSIONAL — Setup test (verifikasi Cloudflare + IMAP end-to-end)        │
# └─────────────────────────────────────────────────────────────────────────┘
# Domain untuk test. Jalankan: python -m mimo.setup_test
TEST_DOMAIN=mimo.domain-anda.com
TEST_SENDER_PASS=                    # kosongkan kalau sama dengan IMAP_PASS


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ OPSIONAL — Referral code (untuk mimo.bot)                              │
# └─────────────────────────────────────────────────────────────────────────┘
# Referral code MiMo UltraSpeed beta. Digunakan oleh `mimo.bot`.
REFERRAL_CODE=MX5V9X


# ┌─────────────────────────────────────────────────────────────────────────┐
# │ OPSIONAL — Batch defaults                                              │
# └─────────────────────────────────────────────────────────────────────────┘
# Default strategi email untuk `mimo.batch` (kalau tidak di-override via CLI).
# Pilihan: catch_all | gmail_plus | from_file
BATCH_EMAIL_STRATEGY=catch_all


# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  Quick reference — variabel per-module                                  ║
# ╠══════════════════════════════════════════════════════════════════════════╣
# ║                                                                         ║
# ║  mimo.register   : CAPSOLVER_API_KEY, EMAIL, XIAOMI_PASSWORD,           ║
# ║                    IMAP_*, USE_PROXY, PROXY_URL                        ║
# ║                                                                         ║
# ║  mimo.batch      : CAPSOLVER_API_KEY, IMAP_*, USE_PROXY, PROXY_URL,   ║
# ║                    BATCH_EMAIL_STRATEGY                                ║
# ║                                                                         ║
# ║  mimo.bot        : CAPSOLVER_API_KEY, USE_PROXY, PROXY_URL,            ║
# ║                    REFERRAL_CODE                                       ║
# ║                                                                         ║
# ║  mimo.refresh    : CAPSOLVER_API_KEY, USE_PROXY, PROXY_URL            ║
# ║                                                                         ║
# ║  mimo.cf_setup   : CF_API_TOKEN, CF_ZONE_ID, CF_ACCOUNT_ID,            ║
# ║                    CF_DEST_EMAIL                                       ║
# ║                                                                         ║
# ║  mimo.setup_test : TEST_DOMAIN, IMAP_USER, IMAP_PASS, TEST_SENDER_PASS ║
# ║                                                                         ║
# ╚══════════════════════════════════════════════════════════════════════════╝